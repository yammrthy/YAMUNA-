</div>

<script>
const weekdayNames=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
const poriyal={
  Mon:{name:'Beans poriyal',qty:'160g raw'},
  Tue:{name:'Beetroot poriyal',qty:'160g raw'},
  Wed:{name:'Okra poriyal',qty:'160g raw'},
  Thu:{name:'Chayote poriyal',qty:'160g raw'},
  Fri:{name:'Cauliflower poriyal',qty:'160g raw'},
  Sat:{name:'Pumpkin poriyal',qty:'160g raw'},
  Sun:{name:'Chicken (skinless)',qty:'130g raw'}
};
const milestoneRanges=['0.5–0.8 kg','1.0–1.6 kg','1.5–2.4 kg','2.0–3.2 kg','2.5–4.0 kg','3.0–4.8 kg','3.2–5.1 kg'];

const container=document.getElementById('weeksContainer');
let weekIdx=0;
for(let startDay=1; startDay<=45; startDay+=7){
  weekIdx++;
  const endDay=Math.min(startDay+6,45);
  const block=document.createElement('div');
  block.className='week-block'+(weekIdx===1?' open':'');
  block.innerHTML=`
    <div class="week-head">
      <div><h4>Week ${weekIdx} — Days ${startDay}–${endDay}</h4><div class="sub">Milestone: ${milestoneRanges[weekIdx-1]} cumulative loss</div></div>
      <div class="chevron">▶</div>
    </div>
    <div class="week-body"></div>`;
  const body=block.querySelector('.week-body');
  for(let d=startDay; d<=endDay; d++){
    const wd=weekdayNames[(d-1)%7];
    const p=poriyal[wd];
    const isWeighDay=(d%7===0)||d===45;
    const row=document.createElement('div');
    row.className='day-row';
    row.innerHTML=`
      <div class="dlabel">DAY ${d}<span class="wd">${wd}</span></div>
      <div class="checks">
        ${chk(d,'lemon','Lemon water','1 lemon, plain water')}
        ${chk(d,'meal1','Meal 1 — eggs + guava + cuc/carrot','2 eggs+1 white · 100g guava · 100g cuc/carrot')}
        ${chk(d,'snack2','Snack 2 — nuts &amp; seeds','25g total')}
        ${chk(d,'meal2',`Meal 2 — rice + dal + ${p.name}`,`40g rice · 30g dal · ${p.qty}`)}
        ${chk(d,'buttermilk','Snack 3 — buttermilk','200ml plain')}
        ${chk(d,'meal3','Meal 3 — mixed legume bowl','40–45g dry mix')}
        ${chk(d,'steps','10,000 steps','tracked on device')}
        ${isWeighDay?`<div class="weighin"><span>Weigh-in</span><input type="number" step="0.1" placeholder="kg"><span class="tgt">Target: ${milestoneRanges[weekIdx-1]} lost</span></div>`:''}
      </div>`;
    body.appendChild(row);
  }
  container.appendChild(block);
  block.querySelector('.week-head').addEventListener('click',()=>block.classList.toggle('open'));
}
function chk(day,key,labelHtml,meta){
  return `<div class="cline"><input type="checkbox" data-track="${day}-${key}"><label>${labelHtml}<span class="meta">${meta}</span></label></div>`;
}
function updateProgress(){
  const boxes=document.querySelectorAll('input[type=checkbox][data-track]');
  const checked=document.querySelectorAll('input[type=checkbox][data-track]:checked').length;
  const pct=boxes.length?Math.round((checked/boxes.length)*100):0;
  document.getElementById('progressFill').style.width=pct+'%';
  document.getElementById('pctLabel').textContent=pct+'%';
}
container.addEventListener('change',e=>{ if(e.target.matches('input[type=checkbox]')) updateProgress(); });
updateProgress();
</script>
</body>
